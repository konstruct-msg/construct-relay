##############################################################################
# construct-relay — environment variables
# Copy to .env and edit before running docker compose up -d
##############################################################################

# Required: gRPC server to forward decrypted traffic to.
UPSTREAM=ams.konstruct.cc:443

# Set to false only if the upstream speaks plain H2 (unusual; default: TLS).
UPSTREAM_TLS=true

# ── Simple deployment: obfs4 on a non-standard port ──────────────────────────
#
# Recommended for most VPS deployments outside Russia.
# Port 9894 is unlisted; port 443/9443 are on RKN watchlists.
# obfs4 traffic is indistinguishable from random noise — any port works.
#
LISTEN_PORT=9894
TLS_SNI_HOST=fra1.digitaloceanspaces.com

# Pick TLS_SNI_HOST to match the VPS provider region:
#   Hetzner DE / FI  →  fra1.digitaloceanspaces.com
#   DigitalOcean AMS →  ams3.digitaloceanspaces.com
#   OVH / Scaleway   →  storage.sbg.cloud.ovh.net
#   Yandex Cloud RU  →  storage.yandexcloud.net
#   Any provider     →  storage.bunnycdn.com

# WebTunnel path — leave empty unless the relay is behind a CDN.
# WebTunnel on a bare IP triggers DPI active probing and gets the IP blocked.
WT_PATH=

# ── RU VPS: за nginx с anti-probe Apple CDN (deploy/nginx-ru-vps.conf) ───────
#
# nginx читает SNI из ClientHello (ssl_preread, без терминирования TLS):
#   api.divany-kresla.uk  →  relay (127.0.0.1:8443)   — только клиенты
#   всё остальное         →  Apple CDN 17.253.144.10:443  ← anti-probe
#
# IP выглядит как CDN-нода Apple. РКН/Shodan видят Apple-сертификат и не
# блокируют IP. Relay доступен только клиентам, знающим правильный SNI.
#
# TLS_SNI_HOST = тот же субдомен, по которому nginx роутит на relay.
# iOS-клиент проверяет SPKI (fingerprint), CN-mismatch не мешает.
#
# LISTEN_PORT=127.0.0.1:8443       # loopback; nginx проксирует порт 443
# TLS_SNI_HOST=api.divany-kresla.uk
# WT_PATH=/api/stream              # WebTunnel OK (nginx — cover-слой)
# TRUSTED_PROXIES=172.16.0.0/12   # Docker bridge (уже по умолчанию)
#
# Alt obfs4 listener (CDN bypass — direct connection without nginx):
ALT_LISTEN_PORT=52143
ALT_LISTEN_ADDR=0.0.0.0:9894

# ── Optional ──────────────────────────────────────────────────────────────────

# Trusted proxy CIDRs: connections from these ranges bypass auth-fail rate
# limiting and per-IP connection limits.  Always include the Docker bridge
# subnet so nginx-proxied clients are never incorrectly banned.
TRUSTED_PROXIES=172.16.0.0/12

# Persistent state directory inside the container (mapped to Docker volume).
STATE_DIR=/data

# Log verbosity: error | warn | info (default) | debug | trace
RUST_LOG=info
